{
    "name": "unirate-api/unirate-bundle",
    "description": "Symfony bundle for the UniRate currency-exchange API — autowired client service, exchange rates, currency conversion, and VAT data.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "symfony-bundle",
        "unirate",
        "currency",
        "currency-converter",
        "exchange-rates",
        "forex",
        "fx",
        "vat",
        "fintech"
    ],
    "homepage": "https://github.com/UniRate-API/unirate-bundle",
    "authors": [
        {
            "name": "Unirate Team",
            "homepage": "https://unirateapi.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "symfony/config": "^5.4|^6.0|^7.0",
        "symfony/dependency-injection": "^5.4|^6.0|^7.0",
        "symfony/http-client": "^5.4|^6.0|^7.0",
        "symfony/http-kernel": "^5.4|^6.0|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0",
        "symfony/framework-bundle": "^5.4|^6.0|^7.0"
    },
    "autoload": {
        "psr-4": {
            "UniRateApi\\Bundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "UniRateApi\\Bundle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
